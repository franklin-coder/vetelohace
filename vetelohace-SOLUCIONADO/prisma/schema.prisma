
generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  userType      UserType  @default(VETERINARIAN) // VETERINARIAN or CLINIC_OWNER
  licenseNumber String?   // Número de licencia veterinaria
  phone         String?
  address       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones NextAuth
  accounts Account[]
  sessions Session[]

  // Relaciones veterinarias
  clinic          Clinic?         @relation(fields: [clinicId], references: [id])
  clinicId        String?
  ownedClinic     Clinic?         @relation("ClinicOwner")
  medicalRecords  MedicalRecord[]
  reports         Report[]

  @@map("users")
}

model Clinic {
  id          String   @id @default(cuid())
  name        String
  address     String
  phone       String
  email       String?
  description String?
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  owner         User     @relation("ClinicOwner", fields: [ownerId], references: [id])
  ownerId       String   @unique
  veterinarians User[]
  clients       Client[]

  @@map("clinics")
}

model Client {
  id               String   @id @default(cuid())
  fullName         String
  phone            String
  email            String?
  address          String?
  identityDocument String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones
  clinic   Clinic @relation(fields: [clinicId], references: [id])
  clinicId String
  pets     Pet[]

  @@map("clients")
}

model Pet {
  id          String    @id @default(cuid())
  name        String
  species     Species
  breed       String?
  age         Int?
  weight      Float?
  color       String?
  gender      Gender?
  birthDate   DateTime?
  photo       String?
  microchip   String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  owner           Client          @relation(fields: [ownerId], references: [id])  
  ownerId         String
  medicalRecords  MedicalRecord[]
  reports         Report[]

  @@map("pets")
}

model MedicalRecord {
  id              String           @id @default(cuid())
  visitDate       DateTime         @default(now())
  reason          String
  symptoms        String?
  diagnosis       String?
  treatment       String?
  medications     String?
  notes           String?
  voiceRecording  String?          // URL del archivo de audio
  transcription   String?          // Transcripción del audio
  vitals          String?          // JSON como string para SQLite
  status          RecordStatus     @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relaciones
  pet           Pet    @relation(fields: [petId], references: [id])
  petId         String
  veterinarian  User   @relation(fields: [veterinarianId], references: [id])
  veterinarianId String
  reports       Report[]

  @@map("medical_records")
}

model Report {
  id                String       @id @default(cuid())
  petName           String
  ownerName         String
  visitDate         DateTime
  diagnosis         String
  medications       String?
  dosage            String?
  recommendations   String?
  nextVisit         DateTime?
  template          ReportTemplate
  content           String       // JSON como string para SQLite
  generatedContent  String?      // Contenido generado por IA
  isPrinted         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relaciones
  pet             Pet           @relation(fields: [petId], references: [id])
  petId           String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  medicalRecordId String
  veterinarian    User          @relation(fields: [veterinarianId], references: [id])
  veterinarianId  String

  @@map("reports")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// Enums
enum UserType {
  VETERINARIAN
  CLINIC_OWNER
}

enum Species {
  DOG
  CAT
  BIRD
  RABBIT
  FISH
  OTHER
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum RecordStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ReportTemplate {
  DOG
  CAT
  BIRD
  RABBIT
  FISH
}
